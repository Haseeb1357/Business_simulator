// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./topaz_sync.db"
}

model GameInstance {
  id              Int      @id @default(autoincrement())
  name            String
  current_quarter Int      @default(1)
  status          String   @default("inputting") // inputting, processing, complete
  gdp_growth      Float    @default(2.5)
  interest_rate   Float    @default(5.0)
  teams           Team[]
  decisions       Decision[]
  results         FinancialSnapshot[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Team {
  id              Int      @id @default(autoincrement())
  gameId          Int
  game            GameInstance @relation(fields: [gameId], references: [id])
  name            String
  company_number  Int
  password        String
  decisions       Decision[]
  results         FinancialSnapshot[]
}

model Decision {
  id                Int      @id @default(autoincrement())
  teamId            Int
  team              Team     @relation(fields: [teamId], references: [id])
  gameId            Int
  game              GameInstance @relation(fields: [gameId], references: [id])
  quarter           Int
  
  // Marketing (stored as JSON strings)
  prices            String   // { p1: { home: 150, export: 170 }, ... }
  advertising       String   // { p1: { trade: 10, press_tv: 12 }, ... }
  
  // Operations & HR
  assembly_workers_recruit Int @default(0)
  assembly_workers_dismiss Int @default(0)
  assembly_workers_train   Int @default(0)
  shift_level              Int @default(1)
  maintenance_hours        Int @default(50)
  
  // Finance
  dividend_pence           Int @default(0)
  management_budget_k      Int @default(120)
  
  status            String   @default("draft") // draft, submitted
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([teamId, quarter])
}

model FinancialSnapshot {
  id              Int      @id @default(autoincrement())
  teamId          Int
  team            Team     @relation(fields: [teamId], references: [id])
  gameId          Int
  game            GameInstance @relation(fields: [gameId], references: [id])
  quarter         Int
  
  // Financial Data stored as JSON strings
  profit_and_loss String
  balance_sheet   String
  cash_flow       String
  operations      String   // Market share, inventory, production stats
  
  // Top Level KPIs for Leaderboard
  net_profit      Float
  share_price     Float
  market_share    Float
  company_value   Float
  
  createdAt       DateTime @default(now())

  @@unique([teamId, quarter])
}
